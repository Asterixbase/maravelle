{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite: dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Supabase: functions serve",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["supabase", "functions", "serve", "--env-file", ".env.local"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
