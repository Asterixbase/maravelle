# ─────────────────────────────────────────────────────────────
# Maravelle — Environment Variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────

# Supabase (London region — eu-west-2)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role (server-side / Edge Functions only — NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudinary
VITE_CLOUDINARY_BASE_URL=https://res.cloudinary.com/your-cloud-name/image/upload

# Google Analytics 4
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=maravelle
SENTRY_AUTH_TOKEN=your_sentry_auth_token
VITE_SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXXX

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Affiliate Networks
AWIN_API_KEY=your_awin_api_key
AWIN_POSTBACK_SECRET=your_awin_postback_secret
RAKUTEN_POSTBACK_TOKEN=your_rakuten_postback_token

# Cron security
CRON_SECRET=your_long_random_cron_secret

# Privacy
IP_HASH_SALT=your_long_random_salt_for_ip_hashing
